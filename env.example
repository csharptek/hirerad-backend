# ── HireRadar Environment Variables ──────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to git!

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/hirerad
# Example for Supabase:
# DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ── Apollo.io ─────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here
# Get from: apollo.io → Settings → Integrations → API Keys

# ── Apify ─────────────────────────────────────────────────────
APIFY_API_TOKEN=your_apify_token_here
# Get from: console.apify.com → Settings → Integrations

# ── Instantly.ai ──────────────────────────────────────────────
INSTANTLY_API_KEY=your_instantly_api_key_here
# Optionally pin a specific campaign (leave blank to auto-create daily)
INSTANTLY_CAMPAIGN_ID=

# ── App ───────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
